{
  "name": "try1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:create": "psql -h localhost -p 5433 -U postgres -c \"CREATE DATABASE hackerapp;\"",
    "db:drop": "psql -h localhost -p 5433 -U postgres -c \"DROP DATABASE hackerapp;\"",
    "fulllint": "eslint && tsc --noEmit",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset --force",
    "db:up": "prisma db push",
    "db:seed": "npx tsx prisma/seed/index.ts",
    "db:clean": "npm run db:reset && npm run db:seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
