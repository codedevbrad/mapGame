    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "mapbox-gl": "^3.20.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "postprocessing": "^6.38.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "satellite.js": "^6.0.2",
    "shadcn": "^4.0.8",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
